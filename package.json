{
    "name": "lighterpack",
    "version": "2.0.0",
    "description": "LighterPack =========== LighterPack is a website to track the gear you take on adventures. It is still in Beta.",
    "scripts": {
        "dev": "nuxt dev",
        "start": "nuxt build && node .output/server/index.mjs",
        "build": "nuxt build",
        "lint:css": "./node_modules/.bin/stylelint \"app/**/*.{css,vue}\" --fix",
        "lint:js": "./node_modules/.bin/eslint --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "prepare": "husky",
        "test:unit": "vitest run",
        "test:unit:watch": "vitest",
        "test:unit:coverage": "vitest run --coverage",
        "test:server": "vitest run --config vitest.server.config.ts",
        "typecheck": "nuxt typecheck",
        "db:migrate": "drizzle-kit migrate"
    },
    "lint-staged": {
        "*.{js,vue}": [
            "prettier --write",
            "eslint --fix"
        ],
        "*.css": [
            "prettier --write",
            "stylelint --fix"
        ],
        "*.{json,md}": [
            "prettier --write"
        ]
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/galenmaly/lighterpack"
    },
    "author": "",
    "license": "GPL-2.0",
    "engines": {
        "node": ">=22"
    },
    "dependencies": {
        "@nuxtjs/seo": "^5.1.0",
        "@pinia/nuxt": "^0.11.3",
        "@resvg/resvg-js": "^2.6.2",
        "axios": "^1.13.6",
        "better-auth": "^1.5.6",
        "better-sqlite3": "^12.8.0",
        "config": "^4.4.1",
        "drizzle-orm": "^0.45.1",
        "form-data": "^4.0.5",
        "formidable": "^3.5.4",
        "isomorphic-dompurify": "^3.7.1",
        "lock": "^1.1.0",
        "mailgun.js": "^12.7.1",
        "marked": "^17.0.5",
        "mongodb": "^7.1.0",
        "nanoid": "^5.1.7",
        "nuxt": "^4.4.2",
        "pinia": "^3.0.4",
        "pino": "^10.3.1",
        "satori": "^0.26.0",
        "sharp": "^0.34.5",
        "sortablejs": "^1.15.7",
        "uuid": "^13.0.0",
        "vue": "^3.5.30",
        "vue-router": "^5.0.4",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@playwright/test": "^1.58.2",
        "@rollup/plugin-commonjs": "^29.0.2",
        "@types/better-sqlite3": "^7.6.13",
        "@types/node": "^25.5.0",
        "@types/sharp": "^0.32.0",
        "@types/sortablejs": "^1.15.9",
        "@typescript-eslint/parser": "^8.58.1",
        "@vitejs/plugin-vue": "^6.0.5",
        "@vitest/coverage-v8": "^4.1.1",
        "@vue/test-utils": "^2.4.6",
        "drizzle-kit": "^0.31.10",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-vue": "^10.8.0",
        "husky": "^9.1.7",
        "jsdom": "^29.0.1",
        "lint-staged": "^16.4.0",
        "pino-pretty": "^13.1.3",
        "postcss-html": "^1.8.1",
        "prettier": "^3.8.1",
        "stylelint": "^17.5.0",
        "stylelint-config-standard": "^40.0.0",
        "stylelint-order": "^8.1.1",
        "typescript": "^6.0.2",
        "vite": "^8.0.2",
        "vitest": "^4.1.1"
    }
}
