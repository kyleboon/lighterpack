{
    "name": "lighterpack",
    "version": "2.0.0",
    "description": "LighterPack =========== LighterPack is a website to track the gear you take on adventures. It is still in Beta.",
    "scripts": {
        "dev": "nuxt dev",
        "start": "nuxt build && node .output/server/index.mjs",
        "build": "nuxt build",
        "lint:css": "./node_modules/.bin/stylelint \"app/**/*.{scss,vue}\" --fix",
        "lint:js": "./node_modules/.bin/eslint --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "prepare": "husky",
        "test:unit": "vitest run",
        "test:unit:watch": "vitest",
        "test:unit:coverage": "vitest run --coverage",
        "typecheck": "nuxt typecheck"
    },
    "lint-staged": {
        "*.{js,vue}": [
            "prettier --write",
            "eslint --fix"
        ],
        "*.{scss,css}": [
            "prettier --write",
            "stylelint --fix"
        ],
        "*.{json,md}": [
            "prettier --write"
        ]
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/galenmaly/lighterpack"
    },
    "author": "",
    "license": "GPL-2.0",
    "engines": {
        "node": ">=22"
    },
    "dependencies": {
        "@pinia/nuxt": "^0.11.3",
        "axios": "^1.13.6",
        "bcryptjs": "^3.0.3",
        "config": "^4.4.1",
        "form-data": "^4.0.5",
        "formidable": "^3.5.4",
        "lock": "^1.1.0",
        "mailgun.js": "^12.7.1",
        "marked": "^17.0.4",
        "mongodb": "^7.1.0",
        "nanoid": "^5.1.7",
        "nuxt": "^4.1.3",
        "pinia": "^3.0.4",
        "sass": "^1.98.0",
        "sortablejs": "^1.15.7",
        "uuid": "^13.0.0",
        "vue": "^3.5.30",
        "vue-router": "^5.0.3"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@playwright/test": "^1.58.2",
        "@rollup/plugin-commonjs": "^29.0.2",
        "@types/node": "^25.5.0",
        "@types/sortablejs": "^1.15.9",
        "@vitejs/plugin-vue": "^6.0.5",
        "@vitest/coverage-v8": "^4.1.0",
        "@vue/test-utils": "^2.4.6",
        "eslint": "^10.0.3",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-vue": "^10.8.0",
        "husky": "^9.1.7",
        "jsdom": "^29.0.0",
        "lint-staged": "^16.4.0",
        "postcss-html": "^1.8.1",
        "postcss-scss": "^4.0.9",
        "prettier": "^3.8.1",
        "stylelint": "^17.4.0",
        "stylelint-config-standard": "^40.0.0",
        "stylelint-order": "^8.1.1",
        "typescript": "^5.9.3",
        "vite": "^8.0.0",
        "vitest": "^4.1.0"
    }
}
